[5.85, "o", "Registered adapters:\r\n"]
[5.88, "o", "  claude_code       available: yes  (Claude Code \u2014 reads ~/.claude/projects/*/*.jsonl)\r\n"]
[5.91, "o", "  codex_cli         available: yes  (Codex CLI \u2014 reads ~/.codex/sessions/**/*.jsonl (v0.3 production))\r\n"]
[5.94, "o", "  copilot-chat      available: yes  (GitHub Copilot Chat \u2014 reads VS Code workspaceStorage chatSessions)\r\n"]
[5.97, "o", "  copilot-cli       available: no  (GitHub Copilot CLI \u2014 reads ~/.copilot/session-state/*/events.jsonl)\r\n"]
[6.0, "o", "  cursor            available: yes  (Cursor IDE \u2014 reads chat history from ~/Library/Application Support/Cursor/)\r\n"]
[6.03, "o", "  gemini_cli        available: yes  (Gemini CLI \u2014 reads ~/.gemini/ session history)\r\n"]
[6.06, "o", "  obsidian          available: yes  (Obsidian \u2014 reads .md files from an Obsidian vault)\r\n"]
[6.09, "o", "  pdf               available: yes  (PDF files \u2014 reads user-configured directories (optional pypdf dep))\r\n"]
