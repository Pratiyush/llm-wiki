[24.02, "o", "\r\n"]
[24.22, "o", "# llmwiki\r\n"]
[24.25, "o", "\r\n"]
[24.28, "o", "> A Karpathy-style LLM Wiki compiled from Claude Code and Codex CLI session transcripts.\r\n"]
[24.31, "o", "\r\n"]
[24.34, "o", "> Version: llmwiki 0.9.0 \u00b7 647 sessions across 30 projects.\r\n"]
[24.37, "o", "\r\n"]
[24.4, "o", "## Home\r\n"]
[24.43, "o", "\r\n"]
[24.46, "o", "- [Home page](index.html): Overview with project cards and living synthesis.\r\n"]
[24.49, "o", "- [All projects](projects/index.html): Browse every project with session counts.\r\n"]
[24.52, "o", "- [All sessions](sessions/index.html): Sortable table of every session.\r\n"]
[24.55, "o", "\r\n"]
[24.58, "o", "## Projects\r\n"]
[24.61, "o", "\r\n"]
[24.64, "o", "- [00---framework---apps](projects/00---framework---apps.html): 50 main sessions, 0 sub-agent runs.\r\n"]
